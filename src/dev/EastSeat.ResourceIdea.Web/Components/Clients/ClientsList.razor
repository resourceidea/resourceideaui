@namespace EastSeat.ResourceIdea.Web.Components.Clients

@inject IMediator Mediator
@inject ListHandler<ClientListDTO> ListHandler

@inherits PagedListSupportBase<ClientListDTO>

<NavLink href="/clients/new" class="mb-2 mt-2 btn btn-primary btn-sm">Add Client</NavLink>

<div class="card">
    <div class="card-header">
        <div class="input-group mb-3 mt-3">
            <input type="text" class="form-control" placeholder="Search clients by name"
                   aria-label="Search clients by name" aria-describedby="button-client-search" @bind="SearchTerm">
            <button class="btn btn-outline-primary" type="button" id="button-client-search" @onclick="SearchClients">
                <i class="fa-solid fa-magnifying-glass"></i>&nbsp;Search Clients
            </button>
        </div>
    </div>
</div>
@if (Items is not null && Items.Count > 0)
{
    <table class="table table-striped table-bordered table-sm">
        <thead class="table-info">
            <tr>
                <th><span @onclick="SortClients">Client name &nbsp;&nbsp;<i class="fa-solid @ListHandler.SortIcon small"></i></span></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var client in Items)
            {
                <tr>
                    <td>
                        <NavLink href="@($"/clients/{client.Id}")">@client.Name</NavLink>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <PagedListBrowser HasPreviousPage="HasPreviousPage"
                      HasNextPage="HasNextPage"
                      OnNext="LoadNextPage"
                      OnPrevious="LoadPreviousPage" />
}
else
{
    <p class="m-3 lead">No clients have been added!</p>
}

@code {
    protected override async Task OnInitializedAsync() => await LoadClientsList(CurrentPage);

    private async Task LoadNextPage() => await ListHandler.LoadNextPage(LoadClientsList);

    private async Task LoadPreviousPage() => await ListHandler.LoadPreviousPage(LoadClientsList);

    private void SortClients() => ListHandler.SortItems(ref Items, c => c.Name);

    private async Task SearchClients() => await ListHandler.SearchItems(LoadClientsList);

    private async Task LoadClientsList(int page)
    {
        var response = await Mediator.Send(new GetClientsListQuery
            {
                Page = page,
                Filter = SearchTerm
            });
        Items = response.Items.ValueOr([]).ToList();
        HasPreviousPage = response.CurrentPage > 1;
        HasNextPage = response.HasNextPage;
    }
}
