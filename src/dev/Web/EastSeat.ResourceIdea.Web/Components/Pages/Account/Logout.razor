@page "/logout"
@inherits ResourceIdeaComponentBase
@using Microsoft.AspNetCore.Identity
@using EastSeat.ResourceIdea.DataStore.Identity.Entities
@using EastSeat.ResourceIdea.Web.Components.Shared.PageTitles

<ResourceIdeaPageTitle Title="Logout" />

<div class="container-fluid vh-100 d-flex align-items-center justify-content-center bg-light">
    <div class="row w-100 justify-content-center">
        <div class="col-md-6 col-lg-4">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-info text-white text-center py-4">
                    <h2 class="mb-0">
                        <i class="fas fa-sign-out-alt me-2"></i>
                        Logout
                    </h2>
                </div>
                <div class="card-body p-5 text-center">
                    @if (IsLoading)
                    {
                        <div class="mb-4">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Signing out...</span>
                            </div>
                            <p class="mt-3 text-muted">Signing you out...</p>
                        </div>
                    }
                    else
                    {
                        <div class="mb-4">
                            <i class="fas fa-check-circle text-success fa-3x mb-3"></i>
                            <p class="mb-4">You have been successfully signed out.</p>
                        </div>

                        <div class="d-grid">
                            <a href="/login" class="btn btn-primary btn-lg">
                                <i class="fas fa-sign-in-alt me-2"></i>
                                Sign In Again
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        border-radius: 15px;
    }

    .card-header {
        border-radius: 15px 15px 0 0 !important;
    }

    .btn-primary {
        border-radius: 8px;
        font-weight: 600;
        padding: 12px 24px;
    }
</style>


